{
  "name": "Social Media Agent",
  "active": false,
  "nodes": [
    {
      "id": "schedule-trigger",
      "name": "Post Schedule",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [250, 300],
      "parameters": {
        "httpMethod": "POST",
        "path": "social-run-{{CLIENT_ID}}",
        "responseMode": "onReceived",
        "responseData": "allEntries"
      }
    },
    {
      "id": "claude-generate-content",
      "name": "Claude - Generate Post Content",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [500, 300],
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "x-api-key", "value": "{{ANTHROPIC_API_KEY}}" },
            { "name": "anthropic-version", "value": "2023-06-01" },
            { "name": "content-type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "{\"model\":\"claude-sonnet-4-20250514\",\"max_tokens\":2048,\"system\":\"You are a social media content expert for {{BUSINESS_NAME}}. {{AGENT_PROMPT}} Create engaging, platform-appropriate social media posts. Return ONLY a valid JSON object where keys are platform names (instagram, facebook, linkedin) and values are the post text strings. No markdown fences, no explanations, just the JSON object.\",\"messages\":[{\"role\":\"user\",\"content\":\"Create one social media post for each of these platforms: instagram, facebook, linkedin. The posts should be relevant to our business and audience. Return ONLY valid JSON.\"}]}"
      }
    },
    {
      "id": "parse-content",
      "name": "Parse Content",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [750, 300],
      "parameters": {
        "jsCode": "const raw = $input.first().json.content?.[0]?.text || '{}';\nconst cleaned = raw.replace(/```json\\n?|\\n?```/g, '').trim();\nlet content;\ntry {\n  content = JSON.parse(cleaned);\n} catch (e) {\n  content = { instagram: raw, facebook: raw, linkedin: raw };\n}\nconst scheduledAt = new Date(Date.now() + 3600000).toISOString();\nreturn Object.entries(content).map(([platform, post]) => ({\n  json: { platform, content: String(post), scheduledTime: scheduledAt }\n}));"
      }
    },
    {
      "id": "schedule-buffer",
      "name": "Schedule via Buffer",
      "type": "@n8n/n8n-nodes-langchain.mcpClient",
      "typeVersion": 1,
      "position": [1000, 300],
      "credentials": {
        "httpBearerAuth": {
          "id": "w7hvzcP37R1AGToc",
          "name": "Bearer Auth account 2"
        }
      },
      "parameters": {
        "endpointUrl": "https://mcp.buffer.com/mcp",
        "authentication": "bearerAuth",
        "tool": {
          "__rl": true,
          "value": "create_post",
          "mode": "list",
          "cachedResultName": "create_post"
        },
        "inputMode": "json",
        "jsonInput": "={\n  \"channelId\": \"={{ $json.platform === 'instagram' ? '{{BUFFER_INSTAGRAM_PROFILE_ID}}' : $json.platform === 'linkedin' ? '{{BUFFER_LINKEDIN_PROFILE_ID}}' : '{{BUFFER_FACEBOOK_PROFILE_ID}}' }}\",\n  \"text\": \"={{ $json.content }}\",\n  \"schedulingType\": \"automatic\"\n}",
        "options": {}
      }
    },
    {
      "id": "log-to-crm",
      "name": "Log Post to CRM",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1250, 300],
      "parameters": {
        "method": "POST",
        "url": "{{API_URL}}/clients/{{CLIENT_ID}}/crm/contacts",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "Bearer {{API_KEY}}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "keypair",
        "bodyParameters": {
          "parameters": [
            { "name": "type", "value": "Note" },
            { "name": "platform", "value": "={{ $json.platform }}" },
            { "name": "body", "value": "={{ 'Social post scheduled for ' + $json.platform + ': ' + $json.content }}" }
          ]
        }
      }
    }
  ],
  "connections": {
    "Post Schedule": {
      "main": [[{ "node": "Claude - Generate Post Content", "type": "main", "index": 0 }]]
    },
    "Claude - Generate Post Content": {
      "main": [[{ "node": "Parse Content", "type": "main", "index": 0 }]]
    },
    "Parse Content": {
      "main": [[{ "node": "Schedule via Buffer", "type": "main", "index": 0 }]]
    },
    "Schedule via Buffer": {
      "main": [[{ "node": "Log Post to CRM", "type": "main", "index": 0 }]]
    }
  },
  "settings": {
    "saveManualExecutions": true
  }
}
